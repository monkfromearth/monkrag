---
/**
 * Grounding demo (Lesson 0.1). Drag the document into the model's context.
 * The same model's answer flips from a confident guess to a grounded fact with a citation.
 * Direct manipulation, reduced-motion safe. The latency numbers elsewhere are illustrative;
 * here nothing is a benchmark, it is purely the idea of "answer from a source."
 */
const W = 380, H = 150;
const homeCx = 70, trayCx = 212, threshold = 150;
---

<div class="mt-demo mr-grounding my-6 bg-white border border-mt-border rounded-2xl p-6"
     data-home={homeCx} data-tray={trayCx} data-thresh={threshold}>
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-3 text-center">Drag the document into the model</p>

    <svg viewBox={`0 0 ${W} ${H}`} class="w-full max-w-lg mx-auto block" role="img" aria-label="drag a document into the model's context to ground its answer">
        <!-- context tray -->
        <text x="212" y="34" text-anchor="middle" class="font-mono" font-size="9" fill="#6B6560">the model's context</text>
        <rect data-tray x="180" y="47" width="64" height="56" rx="8" fill="none" stroke="#C9C2BB" stroke-width="2" stroke-dasharray="5 4"/>

        <!-- arrow into the model -->
        <path d="M247 75 L255 75" stroke="#C9C2BB" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M252 71 L256 75 L252 79" fill="none" stroke="#C9C2BB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>

        <!-- the model -->
        <rect x="258" y="40" width="104" height="70" rx="12" fill="#fff" stroke="#7E7FBC" stroke-width="2.5"/>
        <text x="310" y="80" text-anchor="middle" class="font-mono" font-size="15" font-weight="600" fill="#7E7FBC">LLM</text>
        <text x="310" y="98" text-anchor="middle" font-size="9" fill="#6B6560">the same model</text>

        <!-- draggable document, drawn at home; group translated by x -->
        <g data-doc class="mt-grab" style="cursor:grab">
            <rect x="48" y="47" width="44" height="56" rx="7" fill="#fff" stroke="#7E7FBC" stroke-width="2.5"/>
            <line x1="56" y1="60" x2="84" y2="60" stroke="#C9C2BB" stroke-width="3" stroke-linecap="round"/>
            <line data-hl x1="56" y1="72" x2="84" y2="72" stroke="#C9C2BB" stroke-width="3" stroke-linecap="round"/>
            <line x1="56" y1="84" x2="78" y2="84" stroke="#C9C2BB" stroke-width="3" stroke-linecap="round"/>
            <text x="70" y="116" text-anchor="middle" class="font-mono" font-size="8" fill="#6B6560">launch-notes.md</text>
        </g>
    </svg>

    <div class="mt-4 text-sm max-w-lg mx-auto">
        <p class="mb-1"><span class="font-semibold text-mt-muted">Q</span>&nbsp; What shipped in the Q3 launch?</p>
        <p class="leading-relaxed"><span class="font-semibold text-mt-muted">A</span>&nbsp;
            <span data-guess class="italic text-mt-muted">"I'm not certain, possibly the mobile app."</span>
            <span data-grounded class="font-semibold text-mt-green" hidden>"The billing API and SSO."</span>
        </p>
        <p data-cite class="font-mono text-xs text-mt-green/80 mt-1 ml-5" hidden>source: launch-notes.md</p>
        <div class="mt-3">
            <span data-mode class="tag px-2 py-0.5 rounded-full text-mt-muted bg-stone-100">guessing from memory</span>
        </div>
    </div>
</div>

<script>
    import { gsap, draggable, clamp, REDUCED } from '../../lib/interact';

    document.querySelectorAll<HTMLElement>('.mr-grounding').forEach((root) => {
        const homeCx = Number(root.dataset.home);
        const trayCx = Number(root.dataset.tray);
        const thresh = Number(root.dataset.thresh);
        const dxMax = trayCx - homeCx;

        const svg = root.querySelector<SVGSVGElement>('svg')!;
        const doc = root.querySelector<SVGGElement>('[data-doc]')!;
        const tray = root.querySelector<SVGRectElement>('[data-tray]')!;
        const hl = root.querySelector<SVGLineElement>('[data-hl]')!;
        const guess = root.querySelector<HTMLElement>('[data-guess]')!;
        const grounded = root.querySelector<HTMLElement>('[data-grounded]')!;
        const cite = root.querySelector<HTMLElement>('[data-cite]')!;
        const mode = root.querySelector<HTMLElement>('[data-mode]')!;

        let dx = 0;
        let isGrounded = false;

        function paint() {
            guess.hidden = isGrounded;
            grounded.hidden = !isGrounded;
            cite.hidden = !isGrounded;
            hl.setAttribute('stroke', isGrounded ? '#C96F5A' : '#C9C2BB');
            tray.setAttribute('fill', isGrounded ? '#EFF8F2' : 'none');
            tray.setAttribute('stroke', isGrounded ? '#4F9D7B' : '#C9C2BB');
            mode.textContent = isGrounded ? 'grounded in a source' : 'guessing from memory';
            mode.className = isGrounded
                ? 'tag px-2 py-0.5 rounded-full text-mt-green bg-mt-greenLight'
                : 'tag px-2 py-0.5 rounded-full text-mt-muted bg-stone-100';
        }

        function move(snap: boolean) {
            const to = { x: dx };
            (REDUCED || !snap) ? gsap.set(doc, to) : gsap.to(doc, { ...to, duration: 0.25, ease: 'power2.out', overwrite: true });
            paint();
        }

        // drag: doc center follows the pointer x, clamped between home and tray
        draggable(svg, doc, (x) => {
            const cx = clamp(x, homeCx, trayCx);
            dx = cx - homeCx;
            isGrounded = cx >= thresh;
            move(false);
        });

        // on release, snap into the tray (grounded) or back home (not)
        const settle = () => { isGrounded = dx + homeCx >= thresh; dx = isGrounded ? dxMax : 0; move(true); };
        doc.addEventListener('pointerup', settle);
        doc.addEventListener('pointercancel', settle);

        paint();
    });
</script>
